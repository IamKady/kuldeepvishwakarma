# Gmail API Integration Environment Variables
# Copy this file to .env.local and populate with your credentials

# The Gmail address that has the Gmail API enabled (e.g. kviswakarma43@gmail.com)
GMAIL_USER=kviswakarma43@gmail.com

# Google Cloud OAuth2 Credentials
# Get these from Google Cloud Console -> Credentials
GMAIL_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_client_secret

# OAuth2 Refresh Token (generated with Gmail read/write scopes)
GMAIL_REFRESH_TOKEN=your_oauth2_refresh_token

# The recipient email where you want to receive contact submissions (defaults to GMAIL_USER if empty)
CONTACT_RECEIVER_EMAIL=kviswakarma43@gmail.com
